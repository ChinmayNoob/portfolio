---
import { cfg } from '~/cfg';

const siteLinks = [
  { href: '/now', label: 'Now' },
  { href: '/list-100', label: 'List 100' },
  { href: '/bookshelf', label: 'Bookshelf' },
  { href: '/colophon', label: 'Colophon' },
];

const socialLinks = [
  { href: 'mailto:chinmaypvt04@gmail.com', label: 'Mail' },
  { href: 'https://x.com/Chinmay0408', label: 'X (Twitter)' },
  { href: 'https://github.com/chinmaynoob', label: 'GitHub' },
  {
    href: 'https://www.linkedin.com/in/chinmay-sawant0408/',
    label: 'LinkedIn',
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" transition:persist>
  <div class="content">
    <div class="links links-primary">
      {siteLinks.map(({ href, label }) => <a href={href}>{label}</a>)}
    </div>
    <div class="links links-secondary">
      {
        socialLinks.map(({ href, label }) => (
          <a href={href} target="_blank" rel="me noopener noreferrer">
            {label}
          </a>
        ))
      }
      <a href="/rss.xml" target="_blank" rel="noopener noreferrer">RSS</a>
    </div>
    <div class="banner">
      <span class="emoji">🌱</span>
      <a
        href="https://www.who.int/health-topics/mental-health"
        target="_blank"
        rel="noopener noreferrer"
      >
        Take Care of Your Mind
      </a>
    </div>
    <div class="branding">
      <p class="eyebrow mb-1">Writing from the web</p>
      <span class="name">{cfg.title}</span>
      <p class="description">{cfg.bio.description}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--spacing-page-y);
    position: relative;
    z-index: 2;
    background-color: var(--c-bg);
    width: 100vw;
    max-width: none;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding: min(5rem, var(--spacing-page-y)) var(--spacing-page-x)
      var(--spacing-page-y);
    border-top: 1px solid var(--c-border);
    isolation: isolate;
  }

  .content {
    max-width: var(--spacing-page-w);
    margin: 0 auto;
    display: grid;
    grid-template:
      'links1 links2 branding' auto
      'banner banner branding' auto / minmax(0, 0.8fr) minmax(0, 0.8fr) minmax(
        18rem,
        1.35fr
      );
    align-items: start;
    gap: 1.25rem 1.5rem;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .links-primary {
    grid-area: links1;
  }

  .links-secondary {
    grid-area: links2;
  }

  .links a {
    font-family: var(--font-editorial);
    font-size: 1.125rem;
    line-height: 1.35;
    color: var(--c-text-1);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 4px;
    transition: text-decoration-color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .links a:hover {
      text-decoration-color: currentColor;
    }
  }

  .banner {
    grid-area: banner;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.25rem;
    color: var(--c-text-2);
  }

  .banner .emoji {
    line-height: 1;
  }

  .banner a {
    text-decoration: none;
    color: inherit;
    transition: color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .banner a:hover {
      color: var(--c-text-1);
    }
  }

  .branding {
    grid-area: branding;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 0.65rem;
    max-width: 26rem;
    justify-self: end;
  }

  .eyebrow {
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--c-text-2);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .name {
    font-family: var(--font-editorial);
    font-size: clamp(1.65rem, 2.8vw, 2.2rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--c-text-1);
    text-wrap: balance;
  }

  .description,
  .meta {
    max-width: 28ch;
    line-height: 1.75;
    text-wrap: pretty;
  }

  .description {
    color: var(--c-text-1);
    font-size: 1rem;
  }

  .meta {
    color: var(--c-text-2);
    font-size: 0.95rem;
  }

  @media (max-width: 700px) {
    .site-footer {
      padding-top: 3rem;
    }

    .content {
      grid-template:
        'branding'
        'links1'
        'links2'
        'banner' / 1fr;
      gap: 1.5rem;
    }

    .branding {
      justify-content: flex-start;
      justify-self: start;
      max-width: none;
    }

    .name {
      font-size: 1.25rem;
    }

    .description,
    .meta {
      max-width: none;
    }
  }
</style>
