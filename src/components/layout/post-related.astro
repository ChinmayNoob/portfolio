---
import type { CollectionEntry } from 'astro:content';

interface Props {
  relatedPosts: CollectionEntry<'posts'>[];
}

const { relatedPosts } = Astro.props;

const safeRelated = relatedPosts.filter(
  (p): p is CollectionEntry<'posts'> => Boolean(p?.data?.title),
);
---

{
  safeRelated.length > 0 && (
    <div class="text-text-2">
      <p>Related Posts</p>
      <ul>
        {safeRelated.map((p) => {
          return (
            <li>
              <span class="font-mono">&gt; </span>
              <a class="link text-text-1" href={`/posts/${p.slug}`}>
                {p.data.title}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  )
}
