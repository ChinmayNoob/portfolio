---
import { Image } from 'astro:assets';
import { cfg } from '~/cfg';
import {
  EmailIcon,
  GithubIcon,
  LinkedInIcon,
  XformerlyTwitterIcon,
} from '~/components/ui/icons';

const {
  bio: { avatar, name, description, links },
} = cfg;
---

<div class="mx-auto flex w-fit items-center gap-3">
  {
    avatar && (
      <div class="h-18 w-18 flex-shrink-0 md:h-20 md:w-20">
        <Image
          src={avatar}
          alt="프로필 이미지"
          width={192}
          height={192}
          class="pointer-events-none h-full w-full rounded-full border-4 object-cover select-none"
        />
      </div>
    )
  }
  <div>
    <div class="mb-2 pl-1.5 leading-tight">
      <p class="text-2xl font-bold">
        <slot name="name">{name}</slot>
      </p>
      <p class="font-editorial text-text-2 max-w-sm text-lg leading-snug">
        <slot name="description">{description}</slot>
      </p>
    </div>
    <div class="flex text-xs">
      {
        links.map((link: (typeof cfg.bio.links)[number]) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-2 hover:bg-gray-soft hover:text-text-1 rounded-md p-1.5 transition"
            aria-label={link.label}
          >
            {link.label === 'mail' && <EmailIcon />}
            {link.label === 'github' && <GithubIcon />}
            {link.label === 'x' && <XformerlyTwitterIcon />}
            {link.label === 'linkedin' && <LinkedInIcon />}
          </a>
        ))
      }
    </div>
  </div>
</div>
