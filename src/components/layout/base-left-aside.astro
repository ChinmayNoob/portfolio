---
import { cn } from '~/lib/utils';
---

<aside class={cn('base-right-aside', Astro.props.class)}>
  <slot />
</aside>

<style>
  .base-right-aside {
    display: none;
  }

  @media (min-width: 1380px) {
    .base-right-aside {
      position: fixed;
      top: var(--spacing-page-y);
      right: max(24px, calc((100vw - var(--spacing-page-w)) / 2 - 248px));
      bottom: var(--spacing-page-y);
      z-index: 0;
      display: flex;
      width: 220px;
      overflow: auto;
      scrollbar-width: none;
    }

    .base-right-aside::-webkit-scrollbar {
      display: none;
    }
  }
</style>
