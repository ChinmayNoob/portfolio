---
import '~/styles/global.css';
import '~/styles/custom.css';

import { ClientRouter } from 'astro:transitions';

import { cfg } from '~/cfg';
import BaseHead from '~/components/layout/base-head.astro';
import BaseNav from '~/components/layout/base-nav.astro';
import BaseFooter from '~/components/layout/base-footer.astro';
import type { SEO } from '~/lib/types';

type Props = {
  seo?: SEO;
};

const { seo, ...props } = Astro.props;
const currentPath = new URL(Astro.request.url).pathname;
---

<html lang={cfg.lang}>
  <head>
    <BaseHead {seo} />
    <ClientRouter />
  </head>
  <body>
    <div class="blur-layer" aria-hidden="true"></div>
    <div class="page-shell">
      <aside class="page-nav-rail">
        <BaseNav currentPath={currentPath} />
      </aside>
      <main class="page-main" {...props}>
        <slot />
      </main>
    </div>
    <BaseFooter />
  </body>
</html>
