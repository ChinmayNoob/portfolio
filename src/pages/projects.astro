---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import BaseLayout from '~/components/layout/base-layout.astro';
import ProjectsTagFilter from '~/components/projects/projects-tag-filter';
import {
  buildCanonicalTagRegistry,
  canonicalizeProjectTags,
} from '~/lib/project-tags';

const raw = await getCollection('projects');
const projects = raw.map((project: CollectionEntry<'projects'>) => {
  const d = project.data;
  const hasLinks = Boolean(d.liveUrl || d.githubUrl || d.demoVideoUrl);
  return { project, hasLinks };
});

projects.sort((a, b) => {
  const ao = a.project.data.sortOrder;
  const bo = b.project.data.sortOrder;
  if (ao != null || bo != null) {
    const av = ao ?? 9999;
    const bv = bo ?? 9999;
    if (av !== bv) return av - bv;
  }
  return (
    b.project.data.year - a.project.data.year ||
    a.project.data.title.localeCompare(b.project.data.title)
  );
});

const tagRegistry = buildCanonicalTagRegistry(projects);
const allTags = [...tagRegistry.values()].sort((a, b) => a.localeCompare(b));
---

<BaseLayout
  seo={{
    title: 'Projects',
    description:
      'Selected projects — development, design, and experiments.',
  }}
>
  <article class="prose-index projects-page">
    <section class="flow mt-10" style="--flow-space: 1.75rem">
      <div class="projects-hero flow" style="--flow-space: 0.9rem">
        <h1
          class="projects-title font-editorial text-[clamp(2rem,5vw,3.1rem)] leading-[1.05] tracking-[-0.02em]"
        >
          Projects
        </h1>
        <p class="projects-lede text-text-2 text-xl font-semibold">
          Some of my favorite things I've built.
        </p>
      </div>

      <ProjectsTagFilter
        client:load
        tags={allTags}
        listSelector="#projects-list"
      />

      <ul class="projects-list" id="projects-list" role="list">
      {
        projects.map(({ project, hasLinks }) => {
          const canonicalTags = canonicalizeProjectTags(
            project.data.tags,
            tagRegistry,
          );
          const tagsAttr = canonicalTags.join('|');
          return (
            <li data-project-tags={tagsAttr}>
              <article
                class="project-card"
                aria-labelledby={`project-${project.id.replace(/\W/g, '-')}-title`}
              >
                <div class="project-card-top">
                  <div class="project-card-heading">
                    <h2
                      id={`project-${project.id.replace(/\W/g, '-')}-title`}
                      class="project-card-title font-editorial text-xl leading-snug tracking-[-0.02em] text-text-1 md:text-2xl"
                    >
                      {project.data.title}
                    </h2>
                  </div>
                  <div class="project-card-meta-inline">
                    {project.data.status ? (
                      <span class="project-card-status">{project.data.status}</span>
                    ) : null}
                    <time
                      class="project-card-year font-sans text-sm font-medium text-text-2 tabular-nums"
                      datetime={String(project.data.year)}
                    >
                      {project.data.year}
                    </time>
                  </div>
                </div>

                <p class="project-card-desc text-text-1">{project.data.description}</p>

                <dl class="project-card-meta">
                  <div class="project-meta-row">
                    <dt>Role</dt>
                    <dd>{project.data.role}</dd>
                  </div>
                  <div class="project-meta-row">
                    <dt>Stack</dt>
                    <dd>{project.data.technologies}</dd>
                  </div>
                </dl>

                {hasLinks ? (
                  <nav
                    class="project-card-links"
                    aria-label={`Links for ${project.data.title}`}
                  >
                    {project.data.liveUrl ? (
                      <a
                        href={project.data.liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="project-link"
                      >
                        Live
                      </a>
                    ) : null}
                    {project.data.githubUrl ? (
                      <a
                        href={project.data.githubUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="project-link"
                      >
                        GitHub
                      </a>
                    ) : null}
                    {project.data.demoVideoUrl ? (
                      <a
                        href={project.data.demoVideoUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="project-link"
                      >
                        Demo video
                      </a>
                    ) : null}
                  </nav>
                ) : null}
              </article>
            </li>
          );
        })
      }
    </ul>
    </section>
  </article>
</BaseLayout>

<style>
  .projects-page {
    isolation: isolate;
    width: 100%;
    max-width: 42rem;
    margin-inline: auto;
    overflow-x: visible;
  }

  .projects-title {
    text-wrap: balance;
  }

  .projects-lede {
    max-width: 40rem;
    line-height: 1.75;
    text-wrap: pretty;
  }

  .projects-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card {
    box-sizing: border-box;
    width: 100%;
    border: 1px solid var(--gray-6);
    border-radius: 0.5rem;
    padding: 1rem 1.15rem;
    background: var(--gray-1);
    transition:
      border-color 180ms ease-out,
      background-color 180ms ease-out;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .project-card:hover {
      border-color: var(--gray-8);
      background: var(--gray-2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card {
      transition: none;
    }
  }

  .project-card:focus-within {
    border-color: var(--tomato-9);
    outline: none;
  }

  .project-card-top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-bottom: 0.5rem;
  }

  .project-card-heading {
    flex: 1 1 12rem;
    min-width: 0;
  }

  .project-card-title {
    text-wrap: balance;
    margin: 0;
  }

  .project-card-meta-inline {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .project-card-status {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: capitalize;
    color: var(--gray-11);
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--gray-7);
    border-radius: 0.25rem;
    line-height: 1.2;
  }

  .project-card-year {
    flex: 0 0 auto;
  }

  .project-card-desc {
    margin: 0 0 0.75rem;
    line-height: 1.55;
    text-wrap: pretty;
    font-size: 1rem;
  }

  .project-card-meta {
    display: grid;
    gap: 0.35rem;
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--gray-11);
  }

  .project-meta-row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 0.65rem;
    align-items: baseline;
  }

  .project-meta-row dt {
    margin: 0;
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gray-10);
  }

  .project-meta-row dd {
    margin: 0;
    color: var(--gray-12);
  }

  .project-card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    align-items: center;
    margin-top: 0.15rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: transparent;
    color: var(--gray-12);
    border-radius: 0.375rem;
    transition: text-decoration-color 160ms ease-out, color 160ms ease-out;
  }

  @media (hover: hover) {
    .project-link:hover {
      text-decoration-color: var(--tomato-9);
      color: var(--tomato-11);
    }
  }

  .project-link:focus-visible {
    outline: 2px solid var(--tomato-9);
    outline-offset: 2px;
  }
</style>
