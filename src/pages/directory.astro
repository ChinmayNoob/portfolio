---
import BaseLayout from '~/components/layout/base-layout.astro';
import { getCollection } from 'astro:content';

const pageFiles = import.meta.glob('./**/*.astro', { eager: true });

const staticPages = Object.keys(pageFiles)
  .map((filePath) => {
    const normalized = filePath.replace(/\\/g, '/');
    const rel = normalized.replace(/^\.\//, '').replace(/\.astro$/, '');
    const route =
      rel === 'index'
        ? '/'
        : rel.endsWith('/index')
          ? `/${rel.slice(0, -'/index'.length)}`
          : `/${rel}`;

    const filename = rel.split('/').pop() ?? '';
    const title =
      filename === 'index'
        ? route === '/'
          ? 'Home'
          : route.split('/').filter(Boolean).pop() ?? ''
        : filename;

    return { route, title: title.charAt(0).toUpperCase() + title.slice(1) };
  })
  .filter(
    ({ route, title }) =>
      !route.includes('[') && title !== '404' && route !== '/directory',
  )
  .sort((a, b) => a.title.localeCompare(b.title));

const allContentPages = await getCollection('pages');
const contentPages = allContentPages.filter((page) => page.id !== 'directory');

const collections = await Promise.all([
  getCollection('posts').then((items) => ({
    name: 'Posts',
    path: '/posts',
    count: items.length,
  })),
  getCollection('books').then((items) => ({
    name: 'Bookshelf',
    path: '/bookshelf',
    count: items.length,
  })),
  getCollection('now').then((items) => ({
    name: 'Now',
    path: '/now',
    count: items.length,
  })),
]).then((cols) => cols.sort((a, b) => a.name.localeCompare(b.name)));
---

<BaseLayout
  seo={{
    title: 'Directory',
    description: 'A list of everything on this site',
  }}
>
  <article class="prose-index directory-page">
    <section class="flow mt-10" style="--flow-space: 1.75rem">
      <div class="directory-hero flow" style="--flow-space: 0.9rem">
        <h1
          class="directory-hero-title font-editorial text-[clamp(2rem,5vw,3.1rem)] leading-[1.05] tracking-[-0.02em]"
        >
          Directory
        </h1>
        <p class="directory-hero-copy text-text-2 text-[1.0625rem]">
          A list of everything on this site
        </p>
      </div>

      <div class="directory-body flow" style="--flow-space: 1.5rem">
        <section class="directory-section flow" style="--flow-space: 0.65rem">
          <h2
            class="directory-section-title font-editorial text-[1.85rem] leading-none tracking-[-0.01em]"
          >
            Pages
          </h2>
          <ul class="directory-list m-0 list-none p-0">
            {
              staticPages.map((page) => (
                <li class="directory-item">
                  <a href={page.route} class="link">
                    {page.title}
                  </a>
                </li>
              ))
            }
            {
              contentPages.map((page) => (
                <li class="directory-item">
                  <a href={`/${page.slug}`} class="link">
                    {page.data.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="directory-section flow" style="--flow-space: 0.65rem">
          <h2
            class="directory-section-title font-editorial text-[1.85rem] leading-none tracking-[-0.01em]"
          >
            Collections
          </h2>
          <ul class="directory-list m-0 list-none p-0">
            {
              collections.map((collection) => (
                <li class="directory-item">
                  <a href={collection.path} class="link">
                    {collection.name}
                  </a>
                  <span class="directory-count">({collection.count})</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="directory-section flow" style="--flow-space: 0.65rem">
          <h2
            class="directory-section-title font-editorial text-[1.85rem] leading-none tracking-[-0.01em]"
          >
            Feeds
          </h2>
          <ul class="directory-list m-0 list-none p-0">
            <li class="directory-item">
              <a href="/rss.xml" class="link">
                RSS
              </a>
            </li>
          </ul>
        </section>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .directory-page {
    isolation: isolate;
  }

  .directory-hero-title {
    text-wrap: balance;
  }

  .directory-hero-copy {
    max-width: 40rem;
    line-height: 1.9;
    text-wrap: pretty;
  }

  .directory-body,
  .directory-section-title {
    max-width: 42rem;
  }

  .directory-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .directory-item {
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  .directory-count {
    color: var(--gray-11);
    font-size: 0.875rem;
    margin-left: 0.25rem;
  }
</style>
