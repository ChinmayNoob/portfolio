---
import BaseBio from '~/components/layout/base-bio.astro';
import BaseLayout from '~/components/layout/base-layout.astro';
import { ArrowRightUpIcon } from '~/components/ui/icons';
---

<BaseLayout>
  <article class="prose-index home-page">
    <section class="flow home-stack mt-10" style="--flow-space: 1.75rem">
      <h1
        class="home-intro-copy font-editorial text-[clamp(2rem,5vw,3.1rem)] leading-[1.05] tracking-[-0.02em]"
        data-home-animate
      >
        I'm a backend focused full stack developer. I spend my days building
        systems you don't see, interfaces you remember when it's needed, and
        figuring out how to make ideas work better on the web.
      </h1>

      <div class="pt-4" data-home-animate>
        <BaseBio />
      </div>

      <section
        class="home-section flow"
        style="--flow-space: 0.9rem"
        data-home-animate
      >
        <h2
          class="home-section-title font-editorial text-[1.85rem] leading-none tracking-[-0.01em]"
        >
          Now
        </h2>
        <p class="home-section-body text-text-2 text-[1.0625rem]">
          I'm looking for internships and full time roles. Previously, I held
          various roles at <a
            href="https://www.linkedin.com/in/chinmay-sawant0408/"
            target="_blank"
          >
            startups</a
          >. These days, my focus is on refining the fundamentals of my craft,
          and figuring how to balance all the aspects of my life without
          neglecting any of them.
        </p>
        <p class="home-section-body text-text-2 text-[1.0625rem]">
          Sometimes I <a href="/posts" target="_self">write</a> about what I'm learning;
          other times, I just write.
        </p>
      </section>

      <section
        class="home-section flow"
        style="--flow-space: 0.9rem"
        data-home-animate
      >
        <h2
          class="home-section-title font-editorial text-[1.85rem] leading-none tracking-[-0.01em]"
        >
          More
        </h2>
        <nav class="home-links flex flex-col">
          <a
            href="https://fern-ui.vercel.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="home-link link flex items-center gap-3 text-[1.0625rem]"
          >
            <span class="home-link-icon flex-shrink-0" aria-hidden="true">
              <ArrowRightUpIcon style={{ width: 20, height: 20 }} />
            </span>
            <span class="home-link-label">Visit Fern UI</span>
          </a>
          <a
            href="https://cal.com/chinmaynoob"
            target="_blank"
            rel="noopener noreferrer"
            class="home-link link flex items-center gap-3 text-[1.0625rem]"
          >
            <span class="home-link-icon flex-shrink-0" aria-hidden="true">
              <ArrowRightUpIcon style={{ width: 20, height: 20 }} />
            </span>
            <span class="home-link-label">Schedule a Call with Me</span>
          </a>
        </nav>
      </section>
    </section>
  </article>
</BaseLayout>

<script>
  import { animate, stagger } from 'motion';

  const HOME_INTRO_KEY = 'home-intro-seen';
  const introEase = 'cubic-bezier(0.215, 0.61, 0.355, 1)';
  const animateElements = animate as unknown as (
    target: unknown,
    keyframes: unknown,
    options: unknown,
  ) => void;

  function initHomeIntroMotion() {
    const elements = document.querySelectorAll<HTMLElement>(
      '[data-home-animate]',
    );
    if (!elements.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      elements.forEach((element) => {
        element.style.removeProperty('opacity');
        element.style.removeProperty('transform');
      });
      return;
    }

    if (sessionStorage.getItem(HOME_INTRO_KEY)) {
      elements.forEach((element) => {
        element.style.removeProperty('opacity');
        element.style.removeProperty('transform');
      });
      return;
    }

    sessionStorage.setItem(HOME_INTRO_KEY, 'true');

    elements.forEach((element) => {
      element.style.opacity = '0';
      element.style.transform = 'translateY(12px)';
    });

    requestAnimationFrame(() => {
      animateElements(
        elements,
        {
          opacity: [0, 1],
          transform: ['translateY(12px)', 'translateY(0px)'],
        },
        {
          delay: stagger(0.08),
          duration: 0.35,
          easing: introEase,
        },
      );
    });
  }

  document.addEventListener('DOMContentLoaded', initHomeIntroMotion);
  document.addEventListener('astro:page-load', initHomeIntroMotion);
</script>

<style>
  .home-page {
    isolation: isolate;
  }

  .home-intro-copy,
  .home-section-title {
    text-wrap: balance;
  }

  .home-intro-copy {
    max-width: 32ch;
  }

  .home-section {
    max-width: 42rem;
    padding-top: 0.25rem;
  }

  .home-section-body {
    max-width: 62ch;
    line-height: 1.9;
  }

  .home-links {
    gap: 0.8rem;
  }

  .home-link {
    width: fit-content;
    align-items: center;
    line-height: 1.6;
  }

  .home-link-label {
    text-wrap: pretty;
  }

  .home-link-icon {
    transition: transform 150ms ease;
    will-change: transform;
  }

  @media (hover: hover) and (pointer: fine) {
    .home-link:hover .home-link-icon,
    .home-link:focus-visible .home-link-icon {
      transform: translate3d(2px, -2px, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-link-icon {
      transition: none;
      will-change: auto;
    }

    .home-link:hover .home-link-icon,
    .home-link:focus-visible .home-link-icon {
      transform: none;
    }
  }
</style>
