---
import { getCollection, getEntry } from 'astro:content';
import PostLayout from '~/components/layout/post-layout.astro';
import {
  getPostsCollection,
  getRelatedPosts,
  isDraft,
} from '~/lib/mdx/post';

const rawSlug = Astro.params.slug;
const slug =
  rawSlug == null
    ? ''
    : Array.isArray(rawSlug)
      ? rawSlug.join('/')
      : rawSlug;

if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

let post = await getEntry('posts', slug);

if (!post) {
  const allPosts = await getCollection('posts');
  post =
    allPosts.find((p) => p.slug === slug || p.slug === `${slug}/index`) ??
    undefined;
}

if (!post || isDraft(post)) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const posts = await getPostsCollection();
const index = posts.findIndex((p) => p.id === post.id);

const prevPost = index >= 0 ? posts[index + 1] : undefined;
const nextPost = index >= 0 ? posts[index - 1] : undefined;
const relatedPosts = getRelatedPosts(post, posts);
---

<PostLayout
  post={post}
  prevPost={prevPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
/>
