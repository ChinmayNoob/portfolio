---
export const prerender = false;

import { db, GuestBook, Stamps, desc, eq, asc } from "astro:db";
import BaseLayout from "~/components/layout/base-layout.astro";
import GuestbookEntry from "../components/Guestbook/GuestbookEntry.astro";
import AlertMessage from "../components/Guestbook/AlertMessage.astro";
import Pagination from "../components/Guestbook/Pagination.astro";
import GuestbookForm from "../components/Guestbook/GuestbookForm.astro";

const PER_PAGE = 10;
const defaultStampAsset = "/stamps/default.png";

const generateOptimizedCloudinaryUrl = (url: string) => {
  const uploadMarker = "/image/upload/";
  const index = url.indexOf(uploadMarker);
  if (index === -1) return url;
  const baseUrl = url.substring(0, index + uploadMarker.length);
  const imagePath = url.substring(index + uploadMarker.length);
  const transformation = "w_300,h_375,c_fill,f_auto,q_auto:eco,dpr_auto/";
  return `${baseUrl}${transformation}${imagePath}`;
};

if (Astro.request.method === "POST") {
  const contentType = Astro.request.headers.get("content-type");
  if (!contentType || !contentType.includes("multipart/form-data")) {
    return new Response("Invalid content type", { status: 400 });
  }

  const formData = await Astro.request.formData();
  const author = (formData.get("author") as string)?.trim();
  const link = (formData.get("link") as string)?.trim();
  const content = (formData.get("content") as string)?.trim();
  const country = (formData.get("country") as string)?.trim();

  const isValidUrl = (url: string): boolean => {
    try {
      new URL(url);
      return true;
    } catch {
      return false;
    }
  };

  if (!author || !content || !country || content.length > 150) {
    return Astro.redirect("/guestbook?error=invalid_input");
  }
  if (link && !isValidUrl(link)) {
    return Astro.redirect("/guestbook?error=invalid_link");
  }
  if ((content.match(/https?:\/\//g) || []).length > 1) {
    return Astro.redirect("/guestbook?error=too_many_links");
  }

  await db.insert(GuestBook).values({
    author,
    content,
    country,
    link: link || null,
    timestamp: new Date(),
  });

  return Astro.redirect("/guestbook?success=message_added");
}

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1", 10));
const offset = (page - 1) * PER_PAGE;

const [rawEntries, stampRows] = await Promise.all([
  db
    .select({
      author: GuestBook.author,
      link: GuestBook.link,
      content: GuestBook.content,
      country: GuestBook.country,
      timestamp: GuestBook.timestamp,
      stampImageUrl: Stamps.imageUrl,
      stampHue: Stamps.hue,
    })
    .from(GuestBook)
    .leftJoin(Stamps, eq(GuestBook.country, Stamps.country))
    .orderBy(desc(GuestBook.timestamp))
    .limit(PER_PAGE + 1)
    .offset(offset),
  db
    .select({ country: Stamps.country })
    .from(Stamps)
    .orderBy(asc(Stamps.country)),
]);

const hasNextPage = rawEntries.length > PER_PAGE;
const guestBook = hasNextPage ? rawEntries.slice(0, PER_PAGE) : rawEntries;
const countries = stampRows.map((s) => s.country);

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
---

<BaseLayout
  seo={{
    title: "Guestbook",
    description:
      "A digital guestbook where visitors can leave messages, thoughts, or feedback. Each entry is a snapshot of their visit, complete with a travel stamp from their country.",
  }}
>
  <main>
    <section class="container">
      <header class="hero">
        <h1 class="hero-title">Guestbook</h1>
        <p class="hero-description">Leave a message and get a travel stamp!</p>
      </header>

      <div class="alert-container">
        {
          success && (
            <AlertMessage
              type="success"
              message="Message added successfully!"
            />
          )
        }
        {
          error === "invalid_input" && (
            <AlertMessage
              type="error"
              message="Invalid input. Ensure author and message are filled."
            />
          )
        }
        {
          error === "invalid_link" && (
            <AlertMessage type="error" message="Invalid URL format." />
          )
        }
        {
          error === "too_many_links" && (
            <AlertMessage type="error" message="Too many links in message." />
          )
        }
      </div>
    </section>

    <section class="guestbook-entries">
      {
        guestBook.map((entry) => {
          const imageAssetForEntry = entry.stampImageUrl
            ? generateOptimizedCloudinaryUrl(entry.stampImageUrl)
            : defaultStampAsset;

          const displayCountry = entry.country || "Unknown";
          const displayHue = entry.stampHue || 210;
          const displayImageAlt = entry.stampImageUrl
            ? `Stamp from ${entry.country} for ${entry.author}'s entry`
            : `Default stamp for ${entry.author}'s entry`;

          return (
            <GuestbookEntry
              name={entry.author}
              link={entry.link}
              message={entry.content}
              date={entry.timestamp}
              country={displayCountry}
              imageUrl={imageAssetForEntry}
              imageAlt={displayImageAlt}
              hue={displayHue}
            />
          );
        })
      }
    </section>

    <Pagination
      currentPage={page}
      hasNextPage={hasNextPage}
      hasPrevPage={page > 1}
    />

    <div class="guestbook-actions">
      <button
        id="openGuestbookDialogBtn"
        class="add-entry-btn"
        aria-label="Open guestbook form"
        title="Add your entry"
        type="button"
      >
        Add your entry
      </button>
    </div>
  </main>

  <dialog
    id="guestbookDialog"
    class="guestbook-dialog"
    aria-labelledby="guestbookDialogTitle"
  >
    <div class="dialog-shell">
      <div class="dialog-header">
        <h2 id="guestbookDialogTitle">Leave a message</h2>
        <button
          id="closeGuestbookDialog"
          type="button"
          class="dialog-close-btn"
          aria-label="Close guestbook form"
        >
          x
        </button>
      </div>
      <GuestbookForm countries={countries} />
    </div>
  </dialog>
</BaseLayout>

<style>
  .alert-container {
    margin-bottom: 24px;
  }

  .hero {
    margin-bottom: 1.5rem;
  }

  .hero-title {
    margin: 0;
  }

  .hero-description {
    margin: 0.25rem 0 0;
    color: var(--gray-11);
  }

  .guestbook-entries {
    max-width: 900px;
    margin: 0 auto 48px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    justify-items: center;
    align-items: start;
    text-align: center;
  }

  .guestbook-entries :global(.guestbook-stamp) {
    --stamp-width: 260px;
    margin: 0;
  }

  .guestbook-entries :global(.guestbook-content) {
    align-items: center;
    text-align: center;
  }

  .guestbook-entries :global(.header-row) {
    align-items: center;
    text-align: center;
  }

  .guestbook-entries :global(.entry-name) {
    margin-inline: auto;
  }

  .guestbook-entries :global(.entry-date) {
    text-align: center;
  }

  .guestbook-entries :global(.message-container) {
    text-align: center;
  }

  .guestbook-actions {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .add-entry-btn {
    min-height: 44px;
    padding: 0.625rem 1rem;
    border: 1px solid var(--gray-6);
    border-radius: 8px;
    background: var(--gray-1);
    color: var(--gray-12);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    touch-action: manipulation;
    transition:
      background-color var(--duration-fast, 150ms) ease,
      border-color var(--duration-fast, 150ms) ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .add-entry-btn:hover {
      background: var(--gray-2);
      border-color: var(--gray-7);
    }
  }

  .add-entry-btn:active {
    transform: scale(0.98);
  }

  .guestbook-dialog {
    width: min(92vw, 560px);
    max-height: min(88vh, 820px);
    border: 1px solid var(--gray-6);
    border-radius: 12px;
    padding: 0;
    background: var(--gray-1);
    color: var(--gray-12);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
    inset: 0;
    margin: auto;
    overflow: auto;
  }

  .guestbook-dialog::backdrop {
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(2px);
  }

  .dialog-shell {
    padding: 1rem;
  }

  .dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .dialog-header h2 {
    margin: 0;
    font-size: 1.125rem;
  }

  .dialog-close-btn {
    min-width: 44px;
    min-height: 44px;
    border: 1px solid var(--gray-6);
    border-radius: 999px;
    background: var(--gray-2);
    color: var(--gray-12);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    touch-action: manipulation;
    transition:
      transform var(--duration-fast, 150ms) ease-out,
      background-color var(--duration-fast, 150ms) ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .dialog-close-btn:hover {
      transform: scale(1.03);
      background: var(--gray-3);
    }
  }

  .dialog-close-btn:focus-visible,
  .add-entry-btn:focus-visible {
    outline: 2px solid var(--tomato-9);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .guestbook-entries {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .guestbook-entries :global(.guestbook-stamp) {
      --stamp-width: 250px;
    }
  }
</style>

<script>
  function initGuestbookDialog() {
    const openBtn = document.getElementById("openGuestbookDialogBtn");
    const closeBtn = document.getElementById("closeGuestbookDialog");
    const dialog = document.getElementById("guestbookDialog");

    if (!(openBtn instanceof HTMLButtonElement)) return;
    if (!(closeBtn instanceof HTMLButtonElement)) return;
    if (!(dialog instanceof HTMLDialogElement)) return;

    const isTouchDevice =
      "ontouchstart" in window || navigator.maxTouchPoints > 0;
    let lastActiveElement: Element | null = null;

    openBtn.addEventListener("click", () => {
      lastActiveElement = document.activeElement;
      dialog.showModal();
      if (!isTouchDevice) {
        const firstInput = dialog.querySelector("input, textarea, select");
        if (firstInput instanceof HTMLElement) {
          firstInput.focus();
        }
      }
    });

    closeBtn.addEventListener("click", () => {
      dialog.close();
    });

    dialog.addEventListener("close", () => {
      if (lastActiveElement instanceof HTMLElement) {
        lastActiveElement.focus();
      } else {
        openBtn.focus();
      }
    });

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  }

  initGuestbookDialog();

  document.addEventListener("astro:page-load", initGuestbookDialog);
</script>
